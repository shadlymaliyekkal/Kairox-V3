def render_results(recon):
    elapsed = (datetime.now() - recon.start_ts).total_seconds()
    finish_animation()

    # ── Summary ──
    section_header("MISSION SUMMARY", GOLD)

    meta = Table(box=box.SIMPLE_HEAD, show_header=False,
                 padding=(0,3), border_style=TEAL, expand=False)
    meta.add_column("K", style=f"bold {TEAL}",  no_wrap=True, min_width=20)
    meta.add_column("V", style=f"bold {WHITE}")

    rows = [
        ("  Target",          f"[bold {C1}]{recon.target}[/]"),
        ("  Timestamp",       datetime.now().strftime("%Y-%m-%d  %H:%M:%S")),
        ("  Scan Duration",   f"[bold {GOLD}]{elapsed:.1f}s[/]"),
        ("  Subdomains",      f"[bold {GREEN}]{len(recon.results['subdomains'])}[/]"),
        ("  Live Hosts",      f"[bold {GREEN}]{len(recon.results['live_hosts'])}[/]"),
        ("  URLs Harvested",  f"[bold {PURP}]{len(recon.results['urls'])}[/]"),
        ("  Open Ports",      f"[bold {ORNG}]{len(recon.results['ports'])}[/]"),
        ("  Sensitive Paths", f"[bold {RED}]{len(recon.results['dirs'])}[/]"),
        ("  HIGH Findings",   f"[bold {RED}]{len(recon.findings['HIGH'])}[/]"),
        ("  MEDIUM Findings", f"[bold {ORNG}]{len(recon.findings['MEDIUM'])}[/]"),
        ("  LOW Findings",    f"[bold {GREEN}]{len(recon.findings['LOW'])}[/]"),
    ]
    for k, v in rows:
        meta.add_row(k, v)

    console.print(Panel(
        meta,
        title=f"[bold {GOLD}]  ◈  SCAN SUMMARY  ◈  [/]",
        border_style=GOLD,
        box=box.DOUBLE_EDGE,
        expand=False,
    ))

    # ── Risk tables ──
    section_header("RISK CLASSIFICATION", RED)

    sev_cfg = [
        ("HIGH",   RED,  "🔴 HIGH RISK"),
        ("MEDIUM", ORNG, "🟡 MEDIUM RISK"),
        ("LOW",    GREEN,"🟢 LOW RISK"),
    ]
    for sev, col, title_str in sev_cfg:
        items = recon.findings[sev]
        if not items: continue

        tbl = Table(
            box=box.SIMPLE, show_header=True,
            header_style=f"bold {col}",
            border_style=f"dim {col}",
            padding=(0,2), expand=False,
        )
        tbl.add_column("TYPE",    style=f"dim {col}",   no_wrap=True, min_width=20)
        tbl.add_column("FINDING", style=f"bold {col}")

        for ftype, value in items[:60]:
            tbl.add_row(f"  {ftype.upper().replace('_',' ')}", escape(value))

        extra = len(items) - 60
        console.print(Panel(
            tbl,
            title=f"[bold {col}]  {title_str}  ──  {len(items)} findings  [/]",
            border_style=col,
            box=box.DOUBLE_EDGE,
            expand=False,
        ))
        if extra > 0:
            console.print(f"  [dim {col}]  … and {extra} more {sev} findings[/]\n")

    # ── Subdomains ──
    if recon.results["subdomains"]:
        section_header("DISCOVERED SUBDOMAINS", C1)
        tbl = Table(
            box=box.SIMPLE_HEAD, show_header=True,
            header_style=f"bold {C1}",
            border_style=TEAL,
            padding=(0,2), expand=False,
        )
        tbl.add_column("  #",       style=f"dim {GREY}", justify="right", no_wrap=True, min_width=4)
        tbl.add_column("SUBDOMAIN", style=f"bold {C2}")
        tbl.add_column("SEVERITY",  style=f"bold {WHITE}", no_wrap=True, min_width=10)
        sc = {"HIGH":RED,"MEDIUM":ORNG,"LOW":GREEN}
        for i, s in enumerate(recon.results["subdomains"][:80], 1):
            sev = classify(s)
            tbl.add_row(str(i), s, f"[bold {sc[sev]}]{sev}[/]")
        console.print(tbl)

    # ── Live hosts ──
    if recon.results["live_hosts"]:
        section_header("LIVE HOSTS", GREEN)
        for h in recon.results["live_hosts"][:40]:
            t = Text()
            t.append("  ▶  ", style=f"bold {GREEN}")
            t.append(h, style=f"bold {C1}")
            console.print(t)

    # ── Ports ──
    if recon.results["ports"]:
        section_header("OPEN PORTS & SERVICES", ORNG)
        sc = {"HIGH":RED,"MEDIUM":ORNG,"LOW":GREEN}
        for p in recon.results["ports"]:
            col = sc[classify(p)]
            t = Text()
            t.append("  ●  ", style=f"bold {col}")
            t.append(p, style=f"bold {ORNG}")
            console.print(t)

    # ── Sensitive paths ──
    if recon.results["dirs"]:
        section_header("SENSITIVE PATHS DETECTED", RED)
        for d in recon.results["dirs"]:
            t = Text()
            t.append("  ⚠  ", style=f"bold {RED}")
            t.append(d, style=f"bold {RED}")
            console.print(t)

    # ── API / interesting URLs ──
    interesting = [(tp,v) for sev in ("HIGH","MEDIUM")
                   for tp,v in recon.findings[sev]
                   if tp in ("url","api_endpoint")]
    if interesting:
        section_header("API ENDPOINTS & INTERESTING URLs", PURP)
        for _, u in interesting[:30]:
            t = Text()
            t.append("  ⬡  ", style=f"bold {PURP}")
            t.append(u, style=f"bold {C2}")
            console.print(t)

    # ── Footer ──
    console.print()
    console.print(Rule(style=f"bold {TEAL}", characters="━"))

    footer = Text()
    footer.append("  KAIROX v3  ", style=f"bold {C1}")
    footer.append("◈", style=f"bold {GOLD}")
    footer.append("  by Shadly Maliyekkal  ", style=f"bold {PURP}")
    footer.append("◈", style=f"bold {GOLD}")
    footer.append("  Authorized use only  ", style=f"dim {GREY}")
    console.print(Align.center(footer))
    console.print(Rule(style=f"bold {TEAL}", characters="━"))
    console.print()

    save_report(recon)

