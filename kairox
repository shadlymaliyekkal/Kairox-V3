# ── Severity classification ─────────────────────────────────
HIGH_PATTERNS   = [r"admin", r"login", r"dashboard", r"panel", r"manager",
                   r"api/v\d", r"api/", r"\.env", r"config", r"secret",
                   r"token", r"key", r"passwd", r"password", r"backup",
                   r"\.git", r"\.svn", r"phpmyadmin", r"wp-admin", r"cpanel",
                   r"webmail", r"console", r"swagger", r"graphql", r"actuator"]
MEDIUM_PATTERNS = [r"ftp", r"smtp", r"8080", r"8443", r"8888", r"proxy",
                   r"upload", r"download", r"file", r"static", r"assets",
                   r"old", r"bak", r"test", r"dev", r"staging"]
LOW_PATTERNS    = [r"ssh", r"22/", r"www", r"mail", r"blog", r"news",
                   r"images", r"css", r"js/", r"fonts"]

def classify(text: str) -> str:
    t = text.lower()
    for p in HIGH_PATTERNS:
        if re.search(p, t): return "HIGH"
    for p in MEDIUM_PATTERNS:
        if re.search(p, t): return "MEDIUM"
    return "LOW"

