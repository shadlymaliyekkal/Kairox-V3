# ── Utility helpers ─────────────────────────────────────────
def tool_ok(name: str) -> bool:
    return shutil.which(name) is not None

def run(cmd: list[str], timeout: int = 300) -> tuple[bool, str]:
    """Run a subprocess, capture output, return (success, stdout)."""
    try:
        result = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            timeout=timeout,
        )
        output = (result.stdout or "").strip()
        return True, output
    except subprocess.TimeoutExpired:
        return False, f"[timeout after {timeout}s]"
    except FileNotFoundError:
        return False, f"[command not found: {cmd[0]}]"
    except Exception as exc:
        return False, f"[error: {exc}]"

def lines(raw: str) -> list[str]:
    return [l.strip() for l in raw.splitlines() if l.strip()]

def section_header(title: str):
    console.print()
    console.print(Rule(f"[bold cyan]  {title}  [/]", style="dim cyan"))
    console.print()

# ── Recon modules ───────────────────────────────────────────
class KairoxRecon:
    def __init__(self, target: str):
        self.target   = target.strip().lower().removeprefix("http://").removeprefix("https://").rstrip("/")
        self.results  = {
            "subdomains": [],
            "live_hosts": [],
            "urls":       [],
            "ports":      [],
            "dirs":       [],
        }
        self.findings = {"HIGH": [], "MEDIUM": [], "LOW": []}
        self.start_ts = datetime.now()

    # ── 1. Subdomain enumeration ──────────────────────────
    def run_subdomains(self, prog):
        subs = set()

        if tool_ok("subfinder"):
            prog.log("[cyan]subfinder[/] → running passive subdomain scan …")
            ok, out = run(["subfinder", "-d", self.target, "-all", "-recursive", "-silent"], timeout=180)
            if ok:
                for s in lines(out): subs.add(s.lower())

        if tool_ok("amass"):
            prog.log("[cyan]amass[/] → passive OSINT enumeration …")
            ok, out = run(["amass", "enum", "-passive", "-d", self.target], timeout=240)
            if ok:
                for s in lines(out): subs.add(s.lower())

        # Fallback: DNS brute with built-in wordlist snippet
        if not tool_ok("subfinder") and not tool_ok("amass"):
            prog.log("[yellow]subfinder/amass not found — using DNS fallback …[/]")
            wordlist = ["www","mail","ftp","dev","staging","api","app","test",
                        "admin","vpn","remote","beta","portal","shop","blog",
                        "m","mobile","ns1","ns2","smtp","webmail","cdn","static"]
            import socket
            for word in wordlist:
                host = f"{word}.{self.target}"
                try:
                    socket.gethostbyname(host)
                    subs.add(host)
                except Exception:
                    pass

        self.results["subdomains"] = sorted(subs)
        for s in self.results["subdomains"]:
            sev = classify(s)
            self.findings[sev].append(("subdomain", s))

    # ── 2. Live host probing ──────────────────────────────
    def run_live_hosts(self, prog):
        hosts = []
        input_list = self.results["subdomains"] or [self.target]

        if tool_ok("httpx"):
            prog.log("[cyan]httpx[/] → probing live hosts …")
            host_str = "\n".join(input_list)
            try:
                proc = subprocess.run(
                    ["httpx", "-silent", "-status-code", "-title", "-tech-detect", "-server", "-no-color"],
                    input=host_str,
                    capture_output=True, text=True, timeout=180
                )
                for l in lines(proc.stdout):
                    hosts.append(l)
                    sev = classify(l)
                    self.findings[sev].append(("live_host", l))
            except Exception as exc:
                prog.log(f"[red]httpx error: {exc}[/]")
        else:
            prog.log("[yellow]httpx not found — using curl-based fallback …[/]")
            for h in input_list[:20]:
                for scheme in ("https", "http"):
                    url = f"{scheme}://{h}"
                    ok, out = run(["curl", "-s", "-o", "/dev/null", "-w", "%{http_code}", "-L",
                                   "--max-time", "5", "--connect-timeout", "3", url], timeout=10)
                    if ok and out.strip() in ("200","301","302","403","401"):
                        entry = f"{url} [{out.strip()}]"
                        hosts.append(entry)
                        sev = classify(entry)
                        self.findings[sev].append(("live_host", entry))
                        break

        self.results["live_hosts"] = hosts

    # ── 3. URL harvesting ─────────────────────────────────
    def run_urls(self, prog):
        urls = set()

        if tool_ok("gau"):
            prog.log("[cyan]gau[/] → harvesting URLs from archives …")
            ok, out = run(["gau", "--threads", "10", self.target], timeout=180)
            if ok:
                for u in lines(out):
                    urls.add(u)

        if tool_ok("waybackurls"):
            prog.log("[cyan]waybackurls[/] → Wayback Machine lookup …")
            ok, out = run(["waybackurls", self.target], timeout=120)
            if ok:
                for u in lines(out): urls.add(u)

        for u in list(urls)[:500]:
            sev = classify(u)
            if sev in ("HIGH", "MEDIUM"):
                self.findings[sev].append(("url", u))
            else:
                self.findings["LOW"].append(("url", u))

        self.results["urls"] = sorted(urls)

    # ── 4. Port scanning ─────────────────────────────────
    def run_ports(self, prog):
        if tool_ok("nmap"):
            prog.log("[cyan]nmap[/] → scanning common ports …")
            ok, out = run(
                ["nmap", "-sCV", "-Pn", "-T4",
                 "--open", "-p", "21,22,23,25,53,80,110,143,443,445,3306,3389,5432,6379,8080,8443,8888,27017",
                 self.target],
                timeout=300
            )
            if ok:
                port_lines = []
                for l in lines(out):
                    if re.search(r"\d+/(tcp|udp)\s+open", l):
                        port_lines.append(l)
                        sev = classify(l)
                        self.findings[sev].append(("port", l))
                self.results["ports"] = port_lines
        else:
            prog.log("[yellow]nmap not found — trying socket-based port scan …[/]")
            import socket
            common_ports = [21,22,23,25,53,80,110,143,443,445,3306,3389,5432,6379,8080,8443]
            open_ports = []
            for port in common_ports:
                try:
                    s = socket.socket()
                    s.settimeout(1.5)
                    s.connect((self.target, port))
                    s.close()
                    entry = f"{port}/tcp  open"
                    open_ports.append(entry)
                    self.findings[classify(entry)].append(("port", entry))
                except Exception:
                    pass
            self.results["ports"] = open_ports

    # ── 5. Sensitive path detection ───────────────────────
    def run_dirs(self, prog):
        prog.log("[cyan]path-probe[/] → checking high-value paths …")
        sensitive_paths = [
            "/.env", "/.git/HEAD", "/.git/config", "/robots.txt", "/sitemap.xml",
            "/admin", "/admin/login", "/login", "/dashboard", "/panel",
            "/wp-admin", "/wp-login.php", "/phpmyadmin", "/cpanel",
            "/api", "/api/v1", "/api/v2", "/graphql", "/swagger",
            "/swagger-ui.html", "/actuator", "/actuator/health",
            "/backup", "/backup.zip", "/backup.tar.gz",
            "/config.php", "/config.yml", "/config.json",
            "/.htaccess", "/server-status", "/server-info",
            "/webmail", "/mail", "/console",
            "/debug", "/test", "/trace",
            "/v1/api", "/v2/api", "/rest/api",
            "/_profiler", "/telescope", "/horizon",
        ]
        found = []
        base_urls = []
        if self.results["live_hosts"]:
            for h in self.results["live_hosts"][:5]:
                m = re.match(r"(https?://[^\s/]+)", h)
                if m: base_urls.append(m.group(1))
        if not base_urls:
            base_urls = [f"https://{self.target}", f"http://{self.target}"]

        for base in base_urls[:3]:
            for path in sensitive_paths:
                url = base.rstrip("/") + path
                ok, code = run(
                    ["curl", "-s", "-o", "/dev/null", "-w", "%{http_code}",
                     "--max-time", "5", "--connect-timeout", "3",
                     "-L", url],
                    timeout=10
                )
                if ok and code.strip() in ("200", "301", "302", "403", "401"):
                    entry = f"{url}  [{code.strip()}]"
                    found.append(entry)
                    self.findings["HIGH"].append(("sensitive_path", entry))

        self.results["dirs"] = found

    # ── API endpoint extractor ────────────────────────────
    def extract_api_endpoints(self):
        api_urls = [u for u in self.results["urls"]
                    if re.search(r"api|graphql|rest|v\d/|\.json|\.xml", u, re.I)]
        for u in api_urls:
            self.findings["HIGH"].append(("api_endpoint", u))

    # ── Main runner ───────────────────────────────────────
    def run_all(self):
        steps = [
            ("Subdomain Enumeration",    self.run_subdomains,    "🔍"),
            ("Live Host Detection",      self.run_live_hosts,    "🌐"),
            ("URL Harvesting",           self.run_urls,          "🔗"),
            ("Port Scanning",            self.run_ports,         "🔌"),
            ("Sensitive Path Detection", self.run_dirs,          "📂"),
        ]

        with Progress(
            SpinnerColumn(spinner_name="dots2", style="cyan"),
            TextColumn("[bold white]{task.description}"),
            BarColumn(bar_width=28, style="cyan", complete_style="bright_cyan"),
            TextColumn("[cyan]{task.percentage:>3.0f}%"),
            TimeElapsedColumn(),
            console=console,
            transient=False,
        ) as prog:

            overall = prog.add_task("[bold white]Overall Progress", total=len(steps))

            for name, fn, icon in steps:
                task = prog.add_task(f"{icon}  {name}", total=None)
                fn(prog)
                prog.update(task, completed=1, total=1,
                            description=f"[bright_green]✔[/]  {name}")
                prog.advance(overall)
                time.sleep(0.2)

        self.extract_api_endpoints()

