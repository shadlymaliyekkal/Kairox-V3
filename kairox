    if not target or "." not in target:
        console.print(f"\n  [bold {RED}]✘[/]  Invalid domain. Exiting.\n")
        sys.exit(1)

    console.print()
    scanning_init_anim(target)

    console.print(Panel(
        f"  [bold {TEAL}]Target  [/]  [bold {C1}]{target}[/]\n"
        f"  [bold {TEAL}]Mode    [/]  Passive + Active Reconnaissance\n"
        f"  [bold {TEAL}]Engine  [/]  [bold {C1}]KAIROX v3[/]  ·  by Shadly Maliyekkal",
        title=f"[bold {GOLD}]  ◈  SCAN INITIALIZING  ◈  [/]",
        border_style=GOLD,
        box=box.DOUBLE_EDGE,
        expand=False,
