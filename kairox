def main():
    os.system("clear 2>/dev/null || cls 2>/dev/null")

    animate_banner()
    boot_sequence()
    show_disclaimer()
    require_consent()
    check_tools()

    console.print(f"  [bold {C_GOLD}]◈[/]  [bold color(255)]Enter target domain[/] [dim color(244)](e.g. example.com)[/]")
    target = Prompt.ask(f"  [bold {C_CYAN}]  ❯[/]")
    target = target.strip().lower().removeprefix("http://").removeprefix("https://").rstrip("/")

    if not target or "." not in target:
        console.print(f"\n  [bold {C_RED}]✘[/]  Invalid domain. Exiting.\n")
        sys.exit(1)

    console.print()
    scanning_init_anim(target)

    console.print(Panel(
        f"  [bold {C_TEAL}]Target  [/]  [bold {C_CYAN}]{target}[/]\n"
        f"  [bold {C_TEAL}]Mode    [/]  Passive + Active Reconnaissance\n"
        f"  [bold {C_TEAL}]Engine  [/]  KAIROX v3  ·  by Shadly Maliyekkal",
        title=f"[bold {C_GOLD}]  ◈  SCAN INITIALIZING  ◈  [/]",
        border_style=C_GOLD,
        box=box.DOUBLE_EDGE,
