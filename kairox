def main():
    animate_banner()
    boot_sequence()
    show_disclaimer()
    require_consent()
    check_tools()

    console.print(f"  [bold {GOLD}]◈[/]  [bold {WHITE}]Enter target domain[/]  [dim {GREY}](e.g. example.com)[/]")
    target = Prompt.ask(f"  [bold {C1}]  ❯[/]")
