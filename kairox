class KairoxRecon:
    def __init__(self, target):
        self.target   = target.strip().lower().removeprefix("http://").removeprefix("https://").rstrip("/")
        self.results  = {"subdomains":[],"live_hosts":[],"urls":[],"ports":[],"dirs":[]}
        self.findings = {"HIGH":[],"MEDIUM":[],"LOW":[]}
        self.start_ts = datetime.now()

    def run_subdomains(self, prog):
        subs = set()
        if tool_ok("subfinder"):
            prog.log(f"  [bold {C_CYAN}]►[/] [bold color(255)]subfinder[/] [dim]→ passive subdomain sweep …[/]")
            ok, out = run(["subfinder","-d",self.target,"-all","-recursive","-silent"], 180)
            if ok:
                for s in lns(out): subs.add(s.lower())
        if tool_ok("amass"):
            prog.log(f"  [bold {C_PURPLE}]►[/] [bold color(255)]amass[/] [dim]→ OSINT enumeration …[/]")
            ok, out = run(["amass","enum","-passive","-d",self.target], 240)
            if ok:
                for s in lns(out): subs.add(s.lower())
        if not tool_ok("subfinder") and not tool_ok("amass"):
            prog.log(f"  [bold {C_ORANGE}]►[/] [dim]DNS wordlist fallback …[/]")
            import socket
            wordlist = ["www","mail","ftp","dev","staging","api","app","test",
                        "admin","vpn","remote","beta","portal","shop","blog",
                        "m","mobile","ns1","ns2","smtp","webmail","cdn","static"]
            for word in wordlist:
                host = f"{word}.{self.target}"
                try:
                    socket.gethostbyname(host); subs.add(host)
                except: pass
        self.results["subdomains"] = sorted(subs)
        for s in self.results["subdomains"]:
            self.findings[classify(s)].append(("subdomain", s))

    def run_live_hosts(self, prog):
        hosts = []
        input_list = self.results["subdomains"] or [self.target]
        if tool_ok("httpx"):
            prog.log(f"  [bold {C_GREEN}]►[/] [bold color(255)]httpx[/] [dim]→ probing live hosts …[/]")
            host_str = "\n".join(input_list)
            try:
                proc = subprocess.run(
                    ["httpx","-silent","-status-code","-title","-tech-detect","-server","-no-color"],
                    input=host_str, capture_output=True, text=True, timeout=180
                )
                for l in lns(proc.stdout):
                    hosts.append(l)
                    self.findings[classify(l)].append(("live_host", l))
            except Exception as e:
                prog.log(f"  [dim {C_RED}]httpx error: {e}[/]")
        else:
            prog.log(f"  [bold {C_ORANGE}]►[/] [dim]curl fallback host probe …[/]")
            for h in input_list[:20]:
                for scheme in ("https","http"):
                    url = f"{scheme}://{h}"
                    ok, code = run(["curl","-s","-o","/dev/null","-w","%{http_code}",
                                    "-L","--max-time","5","--connect-timeout","3",url], 10)
                    if ok and code.strip() in ("200","301","302","403","401"):
                        entry = f"{url} [{code.strip()}]"
                        hosts.append(entry)
                        self.findings[classify(entry)].append(("live_host", entry))
                        break
        self.results["live_hosts"] = hosts

    def run_urls(self, prog):
        urls = set()
        if tool_ok("gau"):
            prog.log(f"  [bold {C_PURPLE}]►[/] [bold color(255)]gau[/] [dim]→ archive URL harvest …[/]")
            ok, out = run(["gau","--threads","10",self.target], 180)
            if ok:
                for u in lns(out): urls.add(u)
        if tool_ok("waybackurls"):
            prog.log(f"  [bold {C_PURPLE}]►[/] [bold color(255)]waybackurls[/] [dim]→ Wayback lookup …[/]")
            ok, out = run(["waybackurls",self.target], 120)
            if ok:
                for u in lns(out): urls.add(u)
        for u in list(urls)[:500]:
            sev = classify(u)
            self.findings[sev].append(("url", u))
        self.results["urls"] = sorted(urls)

    def run_ports(self, prog):
        if tool_ok("nmap"):
            prog.log(f"  [bold {C_ORANGE}]►[/] [bold color(255)]nmap[/] [dim]→ port & service scan …[/]")
            ok, out = run(["nmap","-sCV","-Pn","-T4","--open",
                           "-p","21,22,23,25,53,80,110,143,443,445,3306,3389,5432,6379,8080,8443,8888,27017",
                           self.target], 300)
            if ok:
                port_lines = []
                for l in lns(out):
                    if re.search(r"\d+/(tcp|udp)\s+open", l):
                        port_lines.append(l)
                        self.findings[classify(l)].append(("port", l))
                self.results["ports"] = port_lines
        else:
            prog.log(f"  [bold {C_ORANGE}]►[/] [dim]socket port fallback …[/]")
            import socket
            open_ports = []
            for port in [21,22,23,25,53,80,110,143,443,445,3306,3389,5432,6379,8080,8443]:
                try:
                    s = socket.socket(); s.settimeout(1.5)
                    s.connect((self.target, port)); s.close()
                    entry = f"{port}/tcp  open"
                    open_ports.append(entry)
                    self.findings[classify(entry)].append(("port", entry))
                except: pass
            self.results["ports"] = open_ports

    def run_dirs(self, prog):
        prog.log(f"  [bold {C_PINK}]►[/] [bold color(255)]path-probe[/] [dim]→ sensitive endpoint detection …[/]")
        sensitive_paths = [
            "/.env","/.git/HEAD","/.git/config","/robots.txt","/sitemap.xml",
            "/admin","/admin/login","/login","/dashboard","/panel",
            "/wp-admin","/wp-login.php","/phpmyadmin","/cpanel",
            "/api","/api/v1","/api/v2","/graphql","/swagger",
            "/swagger-ui.html","/actuator","/actuator/health",
            "/backup","/backup.zip","/backup.tar.gz",
            "/config.php","/config.yml","/config.json",
            "/.htaccess","/server-status","/server-info",
            "/webmail","/mail","/console","/debug","/test",
            "/v1/api","/v2/api","/rest/api","/_profiler",
            "/telescope","/horizon",
        ]
        found = []
        base_urls = []
        for h in self.results["live_hosts"][:5]:
            m = re.match(r"(https?://[^\s/]+)", h)
            if m: base_urls.append(m.group(1))
        if not base_urls:
            base_urls = [f"https://{self.target}", f"http://{self.target}"]
        for base in base_urls[:3]:
            for path in sensitive_paths:
                url = base.rstrip("/") + path
                ok, code = run(["curl","-s","-o","/dev/null","-w","%{http_code}",
                                 "--max-time","5","--connect-timeout","3","-L",url], 10)
                if ok and code.strip() in ("200","301","302","403","401"):
                    entry = f"{url}  [{code.strip()}]"
                    found.append(entry)
                    self.findings["HIGH"].append(("sensitive_path", entry))
        self.results["dirs"] = found

    def extract_api_endpoints(self):
        for u in self.results["urls"]:
            if re.search(r"api|graphql|rest|v\d/|\.json|\.xml", u, re.I):
                self.findings["HIGH"].append(("api_endpoint", u))

    def run_all(self):
        steps = [
            ("Subdomain Enumeration",    self.run_subdomains,  C_CYAN,   "◈"),
            ("Live Host Detection",      self.run_live_hosts,  C_GREEN,  "◈"),
            ("URL Harvesting",           self.run_urls,        C_PURPLE, "◈"),
            ("Port & Service Scan",      self.run_ports,       C_ORANGE, "◈"),
            ("Sensitive Path Detection", self.run_dirs,        C_PINK,   "◈"),
        ]

        with Progress(
            SpinnerColumn(spinner_name="dots12", style=f"bold {C_CYAN}"),
            TextColumn(f"[bold color(255)]{{task.description}}"),
            BarColumn(bar_width=30, style=C_TEAL, complete_style=C_GREEN,
                      finished_style=f"bold {C_GREEN}"),
            TextColumn(f"[bold {C_GOLD}]{{task.percentage:>3.0f}}%[/]"),
            TimeElapsedColumn(),
            console=console,
            transient=False,
        ) as prog:
            overall = prog.add_task(
                f"[bold {C_CYAN}]  ◈  Overall Progress[/]",
                total=len(steps)
            )
            for name, fn, color, icon in steps:
                task = prog.add_task(
                    f"[bold {color}]{icon}[/]  {name}",
                    total=None
                )
                fn(prog)
                prog.update(task, completed=1, total=1,
                            description=f"[bold {C_GREEN}]✔[/]  {name}")
                prog.advance(overall)
                time.sleep(0.15)

        self.extract_api_endpoints()

