def save_report(recon):
    ts   = recon.start_ts.strftime("%Y%m%d_%H%M%S")
    name = f"kairox_{recon.target.replace('.','_')}_{ts}.json"
    data = {
        "target":    recon.target,
        "timestamp": recon.start_ts.isoformat(),
        "results":   {k: list(v) for k, v in recon.results.items()},
        "findings":  {s: list(i) for s, i in recon.findings.items()},
    }
    try:
        Path(name).write_text(json.dumps(data, indent=2))
        t = Text()
        t.append("  ✔  ", style=f"bold {GREEN}")
        t.append("Report saved  →  ", style=f"dim {GREY}")
        t.append(name, style=f"bold {C1}")
        console.print(t)
        console.print()
    except Exception as e:
        console.print(f"  [bold {RED}]⚠[/]  Could not save report: {e}\n")

