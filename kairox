def animate_banner():
    os.system("clear 2>/dev/null || cls 2>/dev/null")
    n = len(BANNER)

    # ── Phase 1: Matrix rain — characters rain DOWN, each line reveals top→bottom
    FRAMES = 28
    for frame in range(FRAMES):
        progress = frame / (FRAMES - 1)
        frame_lines = []
        for i, line in enumerate(BANNER):
            line_reveal = min(1.0, max(0.0, progress * 1.6 - i * 0.1))
            chars = []
            for j, ch in enumerate(line):
                char_reveal = j / max(len(line)-1, 1)
                if line_reveal > char_reveal + 0.05:
                    chars.append(ch)
                elif line_reveal > char_reveal:
                    chars.append(random.choice(GLITCH_CHARS))
                else:
                    chars.append(random.choice(MATRIX_CHARS) if random.random() < line_reveal * 0.7 else " ")
            t = Text("".join(chars), style=LINE_GRAD[i])
            frame_lines.append(t)

        console.print()
        _print_banner_frame(frame_lines)
        time.sleep(0.03)
        _up(n + 1)

    # ── Phase 2: Glitch flashes — random colour bursts
    GLITCH_COLORS = ["color(201)","color(51)","color(226)","color(196)","color(135)"]
    for g in range(6):
        frame_lines = []
        for i, line in enumerate(BANNER):
            if g < 4 and random.random() < 0.45:
                col = random.choice(GLITCH_COLORS)
                glitched = "".join(
                    random.choice(GLITCH_CHARS) if random.random() < 0.20 else c
                    for c in line
                )
                t = Text(glitched, style=f"bold {col}")
            else:
                t = Text(line, style=f"bold {LINE_GRAD[i]}")
            frame_lines.append(t)
        console.print()
        _print_banner_frame(frame_lines)
        time.sleep(0.055)
        _up(n + 1)

    # ── Phase 3: Colour sweep — cyan shimmer left→right across each line
    SWEEP_FRAMES = 20
    for frame in range(SWEEP_FRAMES):
        sweep_pos = frame / (SWEEP_FRAMES - 1)
        frame_lines = []
        for i, line in enumerate(BANNER):
            t = Text()
            for j, ch in enumerate(line):
                char_pos = j / max(len(line)-1, 1)
                dist = abs(char_pos - sweep_pos)
                if dist < 0.08:
                    t.append(ch, style="bold color(255)")   # white hot centre
                elif dist < 0.18:
                    t.append(ch, style=f"bold {C1}")        # neon cyan halo
                elif dist < 0.30:
                    t.append(ch, style=f"bold {C2}")
                else:
                    t.append(ch, style=f"bold {LINE_GRAD[i]}")
            frame_lines.append(t)
        console.print()
        _print_banner_frame(frame_lines)
        time.sleep(0.04)
        _up(n + 1)

    # ── Phase 4: Final stable render
    console.print()
    for i, line in enumerate(BANNER):
        t = Text(line, style=f"bold {LINE_GRAD[i]}")
        console.print(Align.center(t))

    # ── Subtitle block with animated typing
    console.print()
    time.sleep(0.1)

    # divider
