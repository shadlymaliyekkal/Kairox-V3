# ── Save JSON report ────────────────────────────────────────
def save_report(recon: KairoxRecon):
    ts   = recon.start_ts.strftime("%Y%m%d_%H%M%S")
    name = f"kairox_{recon.target.replace('.','_')}_{ts}.json"
    data = {
        "target":    recon.target,
        "timestamp": recon.start_ts.isoformat(),
        "results":   {k: list(v) for k, v in recon.results.items()},
        "findings":  {sev: list(items) for sev, items in recon.findings.items()},
    }
    try:
        Path(name).write_text(json.dumps(data, indent=2))
        console.print(f"\n[success]  ✔  Report saved →[/] [bright_cyan]{name}[/]\n")
    except Exception as exc:
        console.print(f"[warn]  ⚠  Could not save report: {exc}[/]")

