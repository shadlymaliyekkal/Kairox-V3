def typewriter(text_obj, delay=0.018):
    """Print a Rich Text char-by-char with typewriter effect."""
    raw = text_obj.plain
    for i in range(1, len(raw)+1):
        partial = Text(raw[:i], style=text_obj._spans[0].style if text_obj._spans else "")
        sys.stdout.write(f"\r{str(partial)}")
        sys.stdout.flush()
        time.sleep(delay)
    console.print()

def animated_rule(title, color=C_CYAN, char="━"):
    """Animated rule that draws left-to-right."""
    term_width = console.width or 80
    side_len   = (term_width - len(title) - 4) // 2
    rule_chars = char * side_len

    # draw left side
    line = Text()
    for ch in rule_chars:
        line.append(ch, style=f"bold {color}")
    line.append(f"  {title}  ", style=f"bold {color}")
    for ch in rule_chars:
        line.append(ch, style=f"bold {color}")

    full = rule_chars + f"  {title}  " + rule_chars
    for i in range(1, len(full)+1, 3):
        sys.stdout.write(f"\r\033[2K{full[:i]}")
        sys.stdout.flush()
        time.sleep(0.005)
    sys.stdout.write(f"\r\033[2K")
    console.print(Rule(f"[bold {color}]  {title}  [/]", style=color))

