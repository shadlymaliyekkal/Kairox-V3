    meta = Table(box=box.SIMPLE_HEAD, show_header=False, padding=(0, 3), expand=False)
    meta.add_column("K", style=f"bold {C_TEAL}",  no_wrap=True, min_width=18)
    meta.add_column("V", style="bold color(255)")

    meta.add_row("  Target",         f"[bold {C_CYAN}]{recon.target}[/]")
    meta.add_row("  Timestamp",      datetime.now().strftime("%Y-%m-%d  %H:%M:%S"))
    meta.add_row("  Duration",       f"[bold {C_GOLD}]{elapsed:.1f}s[/]")
    meta.add_row("  Subdomains",     f"[bold {C_GREEN}]{len(recon.results['subdomains'])}[/]")
    meta.add_row("  Live Hosts",     f"[bold {C_GREEN}]{len(recon.results['live_hosts'])}[/]")
    meta.add_row("  URLs Harvested", f"[bold {C_PURPLE}]{len(recon.results['urls'])}[/]")
    meta.add_row("  Open Ports",     f"[bold {C_ORANGE}]{len(recon.results['ports'])}[/]")
    meta.add_row("  Sensitive Paths",f"[bold {C_RED}]{len(recon.results['dirs'])}[/]")
    meta.add_row("  HIGH Findings",  f"[bold {C_RED}]{len(recon.findings['HIGH'])}[/]")
    meta.add_row("  MEDIUM Findings",f"[bold {C_ORANGE}]{len(recon.findings['MEDIUM'])}[/]")
    meta.add_row("  LOW Findings",   f"[bold {C_GREEN}]{len(recon.findings['LOW'])}[/]")

    console.print(Panel(
        meta,
        title=f"[bold {C_GOLD}]  ◈  SCAN SUMMARY  ◈  [/]",
        border_style=C_GOLD,
        box=box.DOUBLE_EDGE,
        expand=False,
    ))

    # ── Risk classification ──
    section_header("RISK CLASSIFICATION", C_RED)

    sev_cfg = [
        ("HIGH",   C_RED,    "╔══ 🔴 HIGH RISK",   box.DOUBLE_EDGE),
        ("MEDIUM", C_ORANGE, "╔══ 🟡 MEDIUM RISK", box.DOUBLE_EDGE),
        ("LOW",    C_GREEN,  "╔══ 🟢 LOW RISK",    box.SIMPLE_HEAD),
    ]
    for sev, color, title_prefix, bx in sev_cfg:
        items = recon.findings[sev]
        if not items: continue

        tbl = Table(box=box.SIMPLE, show_header=True,
                    header_style=f"bold {color}",
                    border_style=f"dim {color}",
                    padding=(0, 2), expand=False)
        tbl.add_column("TYPE",    style=f"dim {color}", no_wrap=True, min_width=18)
        tbl.add_column("FINDING", style=f"bold {color}")

        for ftype, value in items[:60]:
            tbl.add_row(f"  {ftype.upper().replace('_',' ')}", escape(value))

        extra = len(items) - 60
        console.print(Panel(
            tbl,
            title=f"[bold {color}]  {title_prefix}  ──  {len(items)} findings  [/]",
            border_style=color,
            box=bx,
            expand=False,
        ))
        if extra > 0:
            console.print(f"  [dim {color}]… and {extra} more findings[/]\n")

    # ── Subdomains ──
    if recon.results["subdomains"]:
        section_header("DISCOVERED SUBDOMAINS", C_CYAN)
        tbl = Table(box=box.SIMPLE_HEAD, show_header=True,
                    header_style=f"bold {C_CYAN}",
                    border_style=C_TEAL,
                    padding=(0, 2), expand=False)
        tbl.add_column("  #",       style=f"dim {C_GREY}", justify="right", no_wrap=True, min_width=4)
        tbl.add_column("SUBDOMAIN", style=f"bold {C_CYAN}")
        tbl.add_column("SEVERITY",  style="bold color(255)", no_wrap=True, min_width=10)

        sev_style = {"HIGH": C_RED, "MEDIUM": C_ORANGE, "LOW": C_GREEN}
        for i, s in enumerate(recon.results["subdomains"][:80], 1):
            sev = classify(s)
            col = sev_style[sev]
            tbl.add_row(str(i), s, f"[bold {col}]{sev}[/]")
        console.print(tbl)

    # ── Live Hosts ──
    if recon.results["live_hosts"]:
        section_header("LIVE HOSTS", C_GREEN)
        for h in recon.results["live_hosts"][:40]:
            console.print(f"  [bold {C_GREEN}]▶[/]  [bold {C_CYAN}]{escape(h)}[/]")

    # ── Ports ──
    if recon.results["ports"]:
        section_header("OPEN PORTS & SERVICES", C_ORANGE)
        for p in recon.results["ports"]:
            sev = classify(p)
            col = {"HIGH":C_RED,"MEDIUM":C_ORANGE,"LOW":C_GREEN}[sev]
            console.print(f"  [bold {col}]●[/]  [bold {C_ORANGE}]{escape(p)}[/]")

    # ── Sensitive paths ──
    if recon.results["dirs"]:
        section_header("SENSITIVE PATHS DETECTED", C_RED)
        for d in recon.results["dirs"]:
            console.print(f"  [bold {C_RED}]⚠[/]  [bold {C_RED}]{escape(d)}[/]")

    # ── Interesting URLs ──
    interesting = [(t,v) for sev in ("HIGH","MEDIUM")
                   for t,v in recon.findings[sev]
                   if t in ("url","api_endpoint")]
    if interesting:
        section_header("API ENDPOINTS & INTERESTING URLs", C_PURPLE)
        for _, u in interesting[:30]:
            console.print(f"  [bold {C_PURPLE}]⬡[/]  [bold {C_CYAN}]{escape(u)}[/]")

    # ── Footer ──
    console.print()
    footer = Text()
    footer.append("  KAIROX v3  ", style=f"bold {C_CYAN}")
    footer.append("·", style=f"dim {C_GREY}")
    footer.append("  by Shadly Maliyekkal  ", style=f"bold {C_PURPLE}")
    footer.append("·", style=f"dim {C_GREY}")
    footer.append("  For authorized use only  ", style=f"dim {C_GREY}")
    console.print(Rule(style=C_TEAL, characters="━"))
    console.print(Align.center(footer))
    console.print(Rule(style=C_TEAL, characters="━"))
    console.print()

    save_report(recon)

# ── JSON report ─────────────────────────────────────────────────
def save_report(recon):
    ts   = recon.start_ts.strftime("%Y%m%d_%H%M%S")
    name = f"kairox_{recon.target.replace('.','_')}_{ts}.json"
    data = {
        "target":    recon.target,
        "timestamp": recon.start_ts.isoformat(),
        "results":   {k: list(v) for k, v in recon.results.items()},
        "findings":  {s: list(i) for s, i in recon.findings.items()},
    }
    try:
        Path(name).write_text(json.dumps(data, indent=2))
        console.print(f"  [bold {C_GREEN}]✔[/]  Report saved [dim]→[/] [bold {C_CYAN}]{name}[/]\n")
    except Exception as e:
        console.print(f"  [bold {C_RED}]⚠[/]  Could not save: {e}\n")

